@inject AppState AppState
@inject IJSRuntime JS

<aside class="sidebar">

    @* ── Brand Logo ─────────────────────────────── *@
    <div class="sidebar-brand">
        <div class="brand-logo">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 11 12 14 22 4"></polyline>
                <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
            </svg>
        </div>
        <span class="brand-name">TaskFlow</span>
    </div>

    @* ── Primary Navigation ──────────────────────── *@
    <nav class="sidebar-nav">
        <p class="nav-section-label">Menu</p>

        <button id="nav-dashboard" class="nav-item @(AppState.CurrentView == "dashboard" ? "active" : "")"
                @onclick='() => AppState.SetView("dashboard")'>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect>
                <rect x="3" y="14" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect>
            </svg>
            <span>Tổng quan</span>
        </button>

        <button id="nav-board" class="nav-item @(AppState.CurrentView == "board" ? "active" : "")"
                @onclick='() => AppState.SetView("board")'>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="3" y1="9" x2="21" y2="9"></line><line x1="3" y1="15" x2="21" y2="15"></line>
                <line x1="9" y1="9" x2="9" y2="21"></line><line x1="15" y1="9" x2="15" y2="21"></line>
            </svg>
            <span>Bảng công việc</span>
        </button>
    </nav>

    @* ── Categories Section ──────────────────────── *@
    <div class="sidebar-section">
        <div class="section-header">
            <p class="nav-section-label" style="margin:0">Dự án / Danh mục</p>
            <button id="btn-add-category" class="icon-btn" @onclick="ToggleAddCat" title="Thêm danh mục mới">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
            </button>
        </div>

        @if (_showAddCat)
        {
            <div class="cat-add-form">
                <input id="input-new-category" class="cat-add-input" placeholder="Tên danh mục..."
                       @bind="_newCatName" @bind:event="oninput"
                       @onkeydown="HandleCatKey" autofocus />
                <button class="icon-btn accent" @onclick="SubmitAddCat" title="Xác nhận">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                </button>
                <button class="icon-btn" @onclick="CancelAddCat" title="Hủy">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>
        }

        <div class="cat-list">
            <button class="cat-item @(AppState.CategoryFilter == "all" ? "active" : "")"
                    @onclick='() => SelectCategory("all")'>
                <div class="cat-item-left">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect>
                        <rect x="3" y="14" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect>
                    </svg>
                    <span>Tất cả</span>
                </div>
                <span class="cat-count">@AppState.GetCategoryTaskCount("all")</span>
            </button>

            @foreach (var cat in AppState.Categories)
            {
                <div class="category-group">
                    <button class="cat-item @(AppState.CategoryFilter == cat.Id && AppState.SelectedProjectId == null ? "active" : "")"
                            @onclick="() => SelectCategory(cat.Id)">
                        <div class="cat-item-left">
                            <span class="cat-dot cat-@cat.Color"></span>
                            <span style="font-weight: 600;">@cat.Name</span>
                        </div>
                        <span class="cat-count">@AppState.GetCategoryTaskCount(cat.Id)</span>
                    </button>

                    <div class="project-list" style="padding-left: 15px; margin-top: 4px; margin-bottom: 8px;">
                        @foreach (var proj in AppState.Projects.Where(p => p.CategoryId == cat.Id))
                        {
                            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 2px;">
                                <button class="cat-item @(AppState.SelectedProjectId == proj.Id ? "active" : "")"
                                        @onclick="() => SelectProject(proj.Id)" style="min-height: 32px; padding: 4px 10px; flex: 1;">
                                    <div class="cat-item-left">
                                        <span style="font-size: 0.9em; opacity: 0.85;">└ @proj.Name</span>
                                    </div>
                                    <span class="cat-count" style="font-size: 0.7em;">@AppState.GetActiveTaskCount(proj.Id)</span>
                                </button>
                                <button class="icon-btn danger" @onclick="() => RequestDeleteProject(proj.Id)" @onclick:stopPropagation="true" style="margin-left: 4px; opacity: 0.7;" title="Xóa dự án">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path></svg>
                                </button>
                            </div>
                        }

                        @if (_showAddProjForCat == cat.Id)
                        {
                            <div class="cat-add-form" style="margin-left: 10px; margin-top: 4px;">
                                <input class="cat-add-input" placeholder="Tên dự án..."
                                       @bind="_newProjName" @bind:event="oninput"
                                       @onkeydown="(e) => HandleProjKey(e, cat.Id)" autofocus style="font-size: 0.85em; padding: 4px 8px;" />
                                <button class="icon-btn accent" @onclick="() => SubmitAddProj(cat.Id)">
                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                </button>
                                <button class="icon-btn" @onclick="CancelAddProj">
                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                                </button>
                            </div>
                        }
                        else
                        {
                            <button class="cat-item" @onclick="() => ToggleAddProj(cat.Id)" style="min-height: 28px; padding: 2px 10px; color: var(--text-muted); background: transparent;">
                                <div class="cat-item-left">
                                    <span style="font-size: 0.85em; padding-left: 10px;">+ Thêm dự án</span>
                                </div>
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    @* ── Sidebar Footer ──────────────────────────── *@
    <div class="sidebar-footer">
        <div class="theme-row">
            <div class="theme-label">
                @if (AppState.Theme == "dark")
                {
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                    </svg>
                    <span>Chế độ Tối</span>
                }
                else
                {
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="5"></circle>
                        <line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line>
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                        <line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line>
                    </svg>
                    <span>Chế độ Sáng</span>
                }
            </div>
            <button id="btn-theme-toggle" class="toggle-switch @(AppState.Theme == "dark" ? "on" : "")"
                    @onclick="ToggleTheme" aria-label="Chuyển đổi giao diện">
                <span class="toggle-knob"></span>
            </button>
        </div>

        <div class="user-card">
            <div class="user-avatar">AD</div>
            <div class="user-info">
                <span class="user-name">Admin</span>
                <span class="user-role">Quản lý</span>
            </div>
        </div>
    </div>

    @* Custom Confirm Modal *@
    @if (_projectToDelete.HasValue)
    {
        <div class="drawer-overlay" @onclick="CancelDelete">
            <div class="drawer-panel" style="max-width: 400px; height: auto; margin: auto; border-radius: 8px;" @onclick:stopPropagation="true">
                <div class="drawer-header">
                    <h3>Xác nhận xóa dự án</h3>
                </div>
                <div class="drawer-body" style="padding: 20px;">
                    <p>Bạn có chắc chắn muốn xóa dự án này?</p>
                    <p class="text-danger" style="margin-top: 10px; font-size: 0.9em;">Toàn bộ công việc bên trong cũng sẽ bị xóa vĩnh viễn và không thể khôi phục.</p>
                </div>
                <div class="drawer-footer" style="justify-content: flex-end;">
                    <button class="btn-secondary" @onclick="CancelDelete">Hủy</button>
                    <button class="btn-danger" @onclick="ConfirmDeleteProject">Xóa vĩnh viễn</button>
                </div>
            </div>
        </div>
    }

</aside>

@code {
    bool _showAddCat;
    string _newCatName = "";

    void ToggleAddCat() => _showAddCat = !_showAddCat;
    void CancelAddCat() { _showAddCat = false; _newCatName = ""; }

    void SelectCategory(string id)
    {
        AppState.SetCategoryFilter(id);
        AppState.SetView("board");
    }

    void SelectProject(int id)
    {
        AppState.SelectProject(id);
        AppState.SetView("board");
    }

    int? _projectToDelete;

    void RequestDeleteProject(int id)
    {
        _projectToDelete = id;
    }

    void CancelDelete()
    {
        _projectToDelete = null;
    }

    async Task ConfirmDeleteProject()
    {
        if (_projectToDelete.HasValue)
        {
            var id = _projectToDelete.Value;
            _projectToDelete = null;
            await AppState.DeleteProjectAsync(id);
        }
    }

    string? _showAddProjForCat;
    string _newProjName = "";

    void ToggleAddProj(string catId) { _showAddProjForCat = catId; _newProjName = ""; }
    void CancelAddProj() { _showAddProjForCat = null; _newProjName = ""; }

    async Task SubmitAddProj(string catId)
    {
        if (!string.IsNullOrWhiteSpace(_newProjName))
        {
            await AppState.AddProjectAsync(_newProjName, catId);
            CancelAddProj();
        }
    }

    async Task HandleProjKey(KeyboardEventArgs e, string catId)
    {
        if (e.Key == "Enter") await SubmitAddProj(catId);
        else if (e.Key == "Escape") CancelAddProj();
    }

    async Task ToggleTheme()
    {
        var next = AppState.Theme == "dark" ? "light" : "dark";
        AppState.SetTheme(next);
        await JS.InvokeVoidAsync("taskFlow.setTheme", next);
    }

    async Task SubmitAddCat()
    {
        if (!string.IsNullOrWhiteSpace(_newCatName))
        {
            await AppState.AddCategoryAsync(_newCatName);
            _newCatName = "";
            _showAddCat = false;
        }
    }

    async Task HandleCatKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SubmitAddCat();
        else if (e.Key == "Escape") CancelAddCat();
    }
}
