@inject AppState AppState
@inject IJSRuntime JS
@implements IDisposable

@if (AppState.IsDrawerOpen)
{
    <div class="drawer-overlay" @onclick="AppState.CloseDrawer">
        <div class="drawer-panel" @onclick:stopPropagation>

            @* ── Drawer Header ─────────────────────────────────── *@
            <div class="drawer-header">
                <div class="drawer-title-wrap">
                    <div class="drawer-title-icon">
                        @if (_isEdit)
                        {
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                            </svg>
                        }
                        else
                        {
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line>
                            </svg>
                        }
                    </div>
                    <h3>@(_isEdit ? "Chỉnh sửa công việc" : "Tạo công việc mới")</h3>
                </div>
                <button class="drawer-close" @onclick="AppState.CloseDrawer" title="Đóng">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>

            @* ── Form ──────────────────────────────────────────── *@
            <div class="drawer-body">
                @* Title *@
                <div class="form-group">
                    <label class="form-label">Tiêu đề <span class="required">*</span></label>
                    <input id="input-task-title" class="form-input @(_titleError ? "error" : "")"
                           placeholder="Ví dụ: Lập kế hoạch kinh doanh..."
                           @bind="_title" @bind:event="oninput"
                           @onfocus="() => _titleError = false" />
                    @if (_titleError)
                    {
                        <span class="field-error">Vui lòng điền tiêu đề công việc</span>
                    }
                </div>

                @* Description *@
                <div class="form-group">
                    <label class="form-label">Mô tả chi tiết</label>
                    <textarea id="input-task-desc" class="form-textarea auto-resize"
                              placeholder="Mô tả các bước thực hiện, ghi chú..."
                              @bind="_description" @bind:event="oninput"></textarea>
                </div>

                @* Category + Status row *@
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Dự án</label>
                        <select class="form-select" @bind="_projectId">
                            @foreach (var proj in AppState.Projects)
                            {
                                <option value="@proj.Id">@proj.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Trạng thái</label>
                        <select class="form-select" @bind="_status">
                            <option value="todo">Cần làm</option>
                            <option value="inprogress">Đang làm</option>
                            <option value="inreview">Đang duyệt</option>
                            <option value="done">Đã hoàn thành</option>
                        </select>
                    </div>
                </div>

                @* Priority *@
                <div class="form-group">
                    <label class="form-label">Mức độ ưu tiên</label>
                    <div class="priority-pills">
                        <button type="button" class="priority-pill @(_priority == "low" ? "active low" : "")"
                                @onclick='() => _priority = "low"'>Thấp</button>
                        <button type="button" class="priority-pill @(_priority == "medium" ? "active medium" : "")"
                                @onclick='() => _priority = "medium"'>Trung bình</button>
                        <button type="button" class="priority-pill @(_priority == "high" ? "active high" : "")"
                                @onclick='() => _priority = "high"'>Cao</button>
                    </div>
                </div>

                @* Due date *@
                <div class="form-group">
                    <label class="form-label">Hạn chót hoàn thành</label>
                    <input type="date" class="form-input" @bind="_dueDate" />
                </div>

                @* Subtasks *@
                <div class="form-group">
                    <label class="form-label">Công việc con (@_subtasks.Count)</label>

                    @if (_subtasks.Any())
                    {
                        <div class="subtask-list">
                            @foreach (var (sub, i) in _subtasks.Select((s, i) => (s, i)))
                            {
                                <div class="subtask-item">
                                    <button type="button" class="subtask-check @(sub.Completed ? "checked" : "")"
                                            @onclick="() => ToggleSub(i)">
                                        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4">
                                            <polyline points="20 6 9 17 4 12"></polyline>
                                        </svg>
                                    </button>
                                    <span class="@(sub.Completed ? "sub-text-done" : "sub-text")">@sub.Text</span>
                                    <button type="button" class="sub-del" @onclick="() => DeleteSub(i)" title="Xóa">
                                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                            <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
                                        </svg>
                                    </button>
                                </div>
                            }
                        </div>
                    }

                    <div class="subtask-input-wrap">
                        <input id="input-subtask" class="subtask-input" placeholder="Thêm công việc con..."
                               @bind="_newSubText" @bind:event="oninput"
                               @onkeydown="HandleSubtaskKey" />
                        <button type="button" class="btn-add-sub" @onclick="AddSubtask">Thêm</button>
                    </div>
                </div>
            </div>

            @* ── Footer Actions ────────────────────────────────── *@
            <div class="drawer-footer">
                @if (_isEdit)
                {
                    <button class="btn-danger" @onclick="DeleteTask">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="3 6 5 6 21 6"></polyline>
                            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                        </svg>
                        Xóa
                    </button>
                }
                <div class="drawer-footer-right">
                    <button class="btn-secondary" @onclick="AppState.CloseDrawer">Hủy bỏ</button>
                    <button id="btn-save-task" class="btn-primary" @onclick="Submit">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                            <polyline points="17 21 17 13 7 13 7 21"></polyline>
                            <polyline points="7 3 7 8 15 8"></polyline>
                        </svg>
                        @(_isEdit ? "Lưu lại" : "Tạo mới")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // ── Local form state ──────────────────────────────────────────────────────
    string _title = "";
    string _description = "";
    string _status = "todo";
    string _priority = "medium";
    int _projectId;
    DateTime _dueDate = TimeUtils.VNToday;
    List<Subtask> _subtasks = [];
    string _newSubText = "";
    bool _titleError;
    bool _isEdit;

    // ── Populate form when drawer opens ──────────────────────────────────────
    bool _wasOpen;

    protected override void OnInitialized()
    {
        AppState.OnChange += OnStateChanged;
    }

    public void Dispose()
    {
        AppState.OnChange -= OnStateChanged;
    }

    private void OnStateChanged()
    {
        if (AppState.IsDrawerOpen && !_wasOpen)
        {
            // Drawer just opened
            PopulateForm();
            _justOpened = true;
        }
        _wasOpen = AppState.IsDrawerOpen;
        InvokeAsync(StateHasChanged);
    }

    bool _justOpened;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_justOpened)
        {
            _justOpened = false;
            await Task.Delay(50);
            try { await JS.InvokeVoidAsync("taskFlow.autoResizeTextarea", "input-task-desc"); } catch {}
        }
    }

    private void PopulateForm()
    {
        if (AppState.IsNewTask)
        {
            _isEdit = false;
            _title = "";
            _description = "";
            _status = AppState.DefaultStatus;
            _priority = "medium";
            _projectId = AppState.SelectedProjectId ?? AppState.Projects.FirstOrDefault()?.Id ?? 0;
            _dueDate = TimeUtils.VNToday;
            _subtasks = [];
        }
        else if (AppState.EditingTask != null)
        {
            var t = AppState.EditingTask;
            _isEdit = true;
            _title = t.Title;
            _description = t.Description;
            _status = t.Status;
            _priority = t.Priority;
            _projectId = t.ProjectId;
            _dueDate = DateTime.TryParse(t.DueDate, out var d) ? d : TimeUtils.VNToday;
            _subtasks = [.. t.Subtasks];
        }

        _titleError = false;
        _newSubText = "";
    }

    // ── Subtask handlers ──────────────────────────────────────────────────────
    void ToggleSub(int i)
    {
        var s = _subtasks[i];
        _subtasks[i] = s with { Completed = !s.Completed };
    }

    void DeleteSub(int i) => _subtasks.RemoveAt(i);

    void AddSubtask()
    {
        if (!string.IsNullOrWhiteSpace(_newSubText))
        {
            _subtasks.Add(new Subtask(null, _newSubText.Trim(), false));
            _newSubText = "";
        }
    }

    void HandleSubtaskKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddSubtask();
    }

    // ── Submit ────────────────────────────────────────────────────────────────
    async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_title))
        {
            _titleError = true;
            return;
        }

        var input = new TaskInput
        {
            Title = _title.Trim(),
            Description = _description.Trim(),
            Status = _status,
            Priority = _priority,
            ProjectId = _projectId,
            DueDate = _dueDate.ToString("yyyy-MM-dd"),
            Subtasks = _subtasks
        };

        var idToEdit = _isEdit ? AppState.EditingTask?.Id : null;
        
        // Đóng drawer ngay lập tức để UX mượt mà (chờ DB update ngầm)
        AppState.CloseDrawer();

        if (_isEdit && idToEdit != null)
            await AppState.UpdateTaskAsync(idToEdit.Value, input);
        else
            await AppState.AddTaskAsync(input);
    }

    // ── Delete ────────────────────────────────────────────────────────────────
    async Task DeleteTask()
    {
        if (AppState.EditingTask != null)
        {
            var id = AppState.EditingTask.Id;
            AppState.CloseDrawer();
            await AppState.DeleteTaskAsync(id);
        }
    }
}
