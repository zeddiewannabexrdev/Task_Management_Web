@page "/"
@inject AppState AppState
@implements IDisposable

@{
    var tasks = AppState.Tasks;
    var today = TimeUtils.VNToday.ToString("yyyy-MM-dd");

    int total = tasks.Count;
    int inProgress = tasks.Count(t => t.Status == "inprogress");
    int completed = tasks.Count(t => t.Status == "done");
    int overdue = tasks.Count(t => string.Compare(t.DueDate, today, StringComparison.Ordinal) < 0 && t.Status != "done");
    int rate = total > 0 ? (int)Math.Round((double)completed / total * 100) : 0;

    double radius = 54;
    double circ = 2 * Math.PI * radius;
    double offset = circ - (rate / 100.0) * circ;

    var urgentTasks = tasks
        .Where(t => t.Status != "done")
        .OrderByDescending(t => string.Compare(t.DueDate, today) < 0)
        .ThenByDescending(t => t.Priority == "high" ? 3 : t.Priority == "medium" ? 2 : 1)
        .Take(4)
        .ToList();

    var catStats = AppState.Categories.Select(c =>
    {
        var pIds = AppState.Projects.Where(p => p.CategoryId == c.Id).Select(p => p.Id).ToList();
        var ct = tasks.Where(t => pIds.Contains(t.ProjectId)).ToList();
        int r = ct.Count > 0 ? (int)Math.Round((double)ct.Count(t => t.Status == "done") / ct.Count * 100) : 0;
        return new { Cat = c, Total = ct.Count, Done = ct.Count(t => t.Status == "done"), Rate = r };
    }).ToList();

    string GetMotivation() => rate switch
    {
        100 => "Tuyệt vời! Bạn đã hoàn thành tất cả mục tiêu hôm nay! 🎉",
        >= 75 => "Gần xong rồi! Chỉ còn một chút nữa thôi! 💪",
        >= 50 => "Tuyệt! Bạn đã đi được nửa chặng đường! 🚀",
        >= 25 => "Đang đi đúng hướng! Hãy tiếp tục duy trì nhé!",
        0 => total == 0 ? "Hãy tạo công việc đầu tiên để bắt đầu ngày mới!" : "Bắt đầu thôi! Mỗi bước nhỏ là một tiến bộ lớn! ✨",
        _ => "Bắt đầu hành động để giải quyết từng công việc nào!"
    };
}

<div class="dashboard animate-in">

    @* ── Stat Cards ───────────────────────────────────────────────────────── *@
    <section class="stats-grid">
        <div class="stat-card">
            <div class="stat-info">
                <span class="stat-label">Tổng công việc</span>
                <span class="stat-value">@total</span>
            </div>
            <div class="stat-icon total">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
                    <polyline points="2 17 12 22 22 17"></polyline>
                    <polyline points="2 12 12 17 22 12"></polyline>
                </svg>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-info">
                <span class="stat-label">Đang thực hiện</span>
                <span class="stat-value">@inProgress</span>
            </div>
            <div class="stat-icon progress">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polygon points="10 8 16 12 10 16 10 8"></polygon>
                </svg>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-info">
                <span class="stat-label">Quá hạn</span>
                <span class="stat-value @(overdue > 0 ? "danger" : "")">@overdue</span>
            </div>
            <div class="stat-icon overdue">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                    <line x1="12" y1="9" x2="12" y2="13"></line>
                    <line x1="12" y1="17" x2="12.01" y2="17"></line>
                </svg>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-info">
                <span class="stat-label">Đã hoàn thành</span>
                <span class="stat-value success">@completed</span>
            </div>
            <div class="stat-icon done">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
            </div>
        </div>
    </section>

    @* ── Main Grid ────────────────────────────────────────────────────────── *@
    <div class="dashboard-grid">

        @* Left Column *@
        <div class="dashboard-left">

            @* Progress Ring *@
            <div class="panel">
                <h3 class="panel-title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
                        <polyline points="17 6 23 6 23 12"></polyline>
                    </svg>
                    Tiến độ tổng thể
                </h3>
                <div class="progress-ring-wrap">
                    <div class="progress-ring-svg-wrap">
                        <svg width="128" height="128" class="progress-svg">
                            <circle class="ring-track" stroke="var(--border-color)" stroke-width="10"
                                    fill="transparent" r="@radius" cx="64" cy="64" />
                            <circle class="ring-fill" stroke="url(#grad)" stroke-width="10" stroke-linecap="round"
                                    fill="transparent" r="@radius" cx="64" cy="64"
                                    stroke-dasharray="@circ.ToString("F2")"
                                    stroke-dashoffset="@offset.ToString("F2")" />
                            <defs>
                                <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
                                    <stop offset="0%" style="stop-color:#6366f1" />
                                    <stop offset="100%" style="stop-color:#8b5cf6" />
                                </linearGradient>
                            </defs>
                        </svg>
                        <div class="ring-center">
                            <span class="ring-pct">@rate%</span>
                            <span class="ring-label">Hoàn thành</span>
                        </div>
                    </div>
                    <p class="ring-motivation">@GetMotivation()</p>
                </div>
            </div>

            @* Urgent Tasks *@
            <div class="panel">
                <h3 class="panel-title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="8" x2="12" y2="12"></line>
                        <line x1="12" y1="16" x2="12.01" y2="16"></line>
                    </svg>
                    Công việc khẩn cấp / Cần làm ngay
                </h3>
                <div class="urgent-list">
                    @if (urgentTasks.Any())
                    {
                        @foreach (var t in urgentTasks)
                        {
                            var isOverdue = string.Compare(t.DueDate, today) < 0;
                            <div class="urgent-item" @onclick="() => AppState.OpenEditTaskDrawer(t)">
                                <div class="urgent-left">
                                    <span class="urgent-title">@t.Title</span>
                                    <div class="urgent-meta">
                                        <span class="badge priority-@t.Priority">@TaskLabels.Priority[t.Priority]</span>
                                        <span class="@(isOverdue ? "text-danger" : "text-muted") date-label">
                                            @(t.DueDate == today ? "Hôm nay" : isOverdue ? $"Quá hạn ({t.DueDate})" : t.DueDate)
                                        </span>
                                    </div>
                                </div>
                                <span class="status-badge status-@t.Status">@TaskLabels.Status[t.Status]</span>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <span>🎉</span>
                            <span>Không có công việc khẩn cấp nào!</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* Right Column — Category Stats *@
        <div class="panel">
            <h3 class="panel-title">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                </svg>
                Thống kê theo Dự án
            </h3>
            <div class="cat-stats-list">
                @if (catStats.Any())
                {
                    @foreach (var cs in catStats)
                    {
                        <div class="cat-stat-item">
                            <div class="cat-stat-header">
                                <div class="cat-stat-name">
                                    <span class="cat-dot cat-@cs.Cat.Color"></span>
                                    <span>@cs.Cat.Name</span>
                                </div>
                                <span class="cat-stat-count">@cs.Done/@cs.Total (@cs.Rate%)</span>
                            </div>
                            <div class="progress-bar-track">
                                <div class="progress-bar-fill cat-@cs.Cat.Color" style="width:@cs.Rate%"></div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state">
                        <span>📁</span>
                        <span>Chưa có danh mục nào. Hãy thêm từ sidebar!</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>


@code {
    protected override void OnInitialized()
    {
        AppState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }
}
