@page "/board"
@inject AppState AppState
@inject IJSRuntime JS
@implements IDisposable

@{
    var filtered = AppState.GetFilteredTasks();
    bool filtersActive = AppState.PriorityFilter != "all" || AppState.DateFilter != "all";
}

<div class="board-container animate-in">

    @if (!AppState.SelectedProjectId.HasValue)
    {
        <div class="empty-state" style="margin-top: 100px;">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".3">
                <rect x="3" y="3" width="18" height="18" rx="2"></rect>
                <line x1="9" y1="3" x2="9" y2="21"></line>
            </svg>
            <span style="margin-top: 20px; font-size: 1.1em; color: var(--text-muted);">Vui lòng chọn một Dự án ở menu bên trái để hiển thị bảng công việc.</span>
        </div>
    }
    else
    {
        var activeProject = AppState.Projects.FirstOrDefault(p => p.Id == AppState.SelectedProjectId.Value);
        var projCat = activeProject != null ? AppState.Categories.FirstOrDefault(c => c.Id == activeProject.CategoryId) : null;
        
    @* ── Board Controls ──────────────────────────────────────────────────── *@
    <div class="board-controls">
        <div class="view-toggle">
            <h2 style="margin:0; font-size: 1.2em; display:flex; align-items:center; gap: 8px;">
                @if (projCat != null)
                {
                    <span class="cat-dot cat-@projCat.Color"></span>
                }
                @(activeProject?.Name ?? "Bảng công việc")
            </h2>
            <div style="width: 20px;"></div>
            <button id="btn-view-board" class="view-btn @(_view == "board" ? "active" : "")"
                    @onclick='() => _view = "board"' title="Bảng Kanban">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="18" height="18" rx="2"></rect>
                    <line x1="3" y1="9" x2="21" y2="9"></line><line x1="3" y1="15" x2="21" y2="15"></line>
                    <line x1="9" y1="9" x2="9" y2="21"></line><line x1="15" y1="9" x2="15" y2="21"></line>
                </svg>
                <span>Bảng</span>
            </button>
            <button id="btn-view-list" class="view-btn @(_view == "list" ? "active" : "")"
                    @onclick='() => _view = "list"' title="Danh sách">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line>
                    <line x1="8" y1="18" x2="21" y2="18"></line>
                    <line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line>
                    <line x1="3" y1="18" x2="3.01" y2="18"></line>
                </svg>
                <span>Danh sách</span>
            </button>
        </div>

        <div class="board-filters">
            <select class="filter-select" value="@AppState.PriorityFilter"
                    @onchange="OnPriorityChange">
                <option value="all">Mọi ưu tiên</option>
                <option value="high">Ưu tiên Cao</option>
                <option value="medium">Ưu tiên TB</option>
                <option value="low">Ưu tiên Thấp</option>
            </select>

            <select class="filter-select" value="@AppState.DateFilter"
                    @onchange="OnDateFilterChange">
                <option value="all">Mọi thời hạn</option>
                <option value="today">Hôm nay</option>
                <option value="week">7 ngày tới</option>
                <option value="overdue">Quá hạn</option>
            </select>

            @if (filtersActive)
            {
                <button class="btn-clear-filter" @onclick="AppState.ClearFilters">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                    Xóa bộ lọc
                </button>
            }
        </div>
    </div>

    @* ── Kanban Board View ───────────────────────────────────────────────── *@
    @if (_view == "board")
    {
        <div class="kanban-grid">
            @foreach (var col in TaskLabels.Columns)
            {
                var colTasks = filtered.Where(t => t.Status == col.Id).ToList();
                bool isDragOver = _dragOverCol == col.Id;

                <div class="kanban-col @(isDragOver ? "drag-over" : "")"
                     @ondragover:preventDefault
                     @ondragover="() => _dragOverCol = col.Id"
                     @ondragleave="() => _dragOverCol = null"
                     @ondrop="() => HandleDrop(col.Id)">

                    <div class="col-header">
                        <div class="col-title-wrap">
                            <span class="col-dot @col.Dot"></span>
                            <span class="col-title">@col.Title</span>
                        </div>
                        <span class="col-count">@colTasks.Count</span>
                    </div>

                    <div class="col-tasks">
                        @foreach (var task in colTasks)
                        {
                            <TaskCard Task="task" />
                        }
                        @if (!colTasks.Any())
                        {
                            <div class="col-empty">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".3">
                                    <rect x="3" y="3" width="18" height="18" rx="2"></rect>
                                    <line x1="12" y1="8" x2="12" y2="16"></line><line x1="8" y1="12" x2="16" y2="12"></line>
                                </svg>
                                <span>Kéo thả hoặc tạo mới</span>
                            </div>
                        }
                    </div>

                    <button class="col-add-btn" @onclick="() => AppState.OpenNewTaskDrawer(col.Id)">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line>
                        </svg>
                        Thêm công việc
                    </button>
                </div>
            }
        </div>
    }

    @* ── List View ───────────────────────────────────────────────────────── *@
    else
    {
        var today = DateTime.Today.ToString("yyyy-MM-dd");
        <div class="list-wrap">
            <table class="task-table">
                <thead>
                    <tr>
                        <th>Tiêu đề</th>
                        <th>Dự án</th>
                        <th>Ưu tiên</th>
                        <th>Hạn chót</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (filtered.Any())
                    {
                        @foreach (var t in filtered)
                        {
                            var p = AppState.Projects.FirstOrDefault(pr => pr.Id == t.ProjectId);
                            var c = p != null ? AppState.Categories.FirstOrDefault(cat => cat.Id == p.CategoryId) : null;
                            var isDone = t.Status == "done";
                            var isOverdue = !isDone && string.Compare(t.DueDate, today) < 0;
                            var tomorrowStr = DateTime.Today.AddDays(1).ToString("yyyy-MM-dd");
                            var dateLabel = t.DueDate == today ? "Hôm nay"
                                          : t.DueDate == tomorrowStr ? "Ngày mai"
                                          : isOverdue ? $"Quá hạn ({t.DueDate})"
                                          : t.DueDate;
                            var dateCls = isDone ? "date-done" : isOverdue ? "date-overdue" : t.DueDate == today ? "date-today" : "date-normal";

                            <tr class="task-row" @onclick="() => AppState.OpenEditTaskDrawer(t)">
                                <td class="row-title-cell">
                                    <button class="row-check @(isDone ? "checked" : "")"
                                            @onclick:stopPropagation
                                            @onclick="() => ToggleDone(t)">
                                        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4">
                                            <polyline points="20 6 9 17 4 12"></polyline>
                                        </svg>
                                    </button>
                                    <span class="@(isDone ? "title-done" : "")">@t.Title</span>
                                </td>
                                <td>
                                    @if (p != null)
                                    {
                                        <div class="row-cat">
                                            @if (c != null)
                                            {
                                                <span class="cat-dot cat-@c.Color"></span>
                                            }
                                            <span>@p.Name</span>
                                        </div>
                                    }
                                </td>
                                <td><span class="badge priority-@t.Priority">@TaskLabels.Priority[t.Priority]</span></td>
                                <td><span class="date-cell @dateCls">@dateLabel</span></td>
                                <td><span class="status-badge status-@t.Status">@TaskLabels.Status[t.Status]</span></td>
                                <td class="row-actions" @onclick:stopPropagation>
                                    <button class="action-btn" @onclick="() => AppState.OpenEditTaskDrawer(t)" title="Sửa">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                        </svg>
                                    </button>
                                    <button class="action-btn danger" @onclick="() => DeleteTask(t.Id)" title="Xóa">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <polyline points="3 6 5 6 21 6"></polyline>
                                            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                                            <path d="M10 11v6"></path><path d="M14 11v6"></path>
                                        </svg>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="table-empty">Không có công việc nào thỏa điều kiện lọc.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    }
    }
</div>

@code {
    string _view = "board";
    string? _dragOverCol;

    protected override void OnInitialized()
    {
        AppState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }

    void OnPriorityChange(ChangeEventArgs e)
        => AppState.SetPriorityFilter(e.Value?.ToString() ?? "all");

    void OnDateFilterChange(ChangeEventArgs e)
        => AppState.SetDateFilter(e.Value?.ToString() ?? "all");

    async Task HandleDrop(string colId)
    {
        _dragOverCol = null;
        var idStr = await JS.InvokeAsync<string>("taskFlow.getDragId");
        if (int.TryParse(idStr, out int taskId))
            await AppState.UpdateTaskStatusAsync(taskId, colId);
    }

    async Task ToggleDone(TaskItem t)
    {
        var next = t.Status == "done" ? "todo" : "done";
        await AppState.UpdateTaskStatusAsync(t.Id, next);
    }

    async Task DeleteTask(int id)
        => await AppState.DeleteTaskAsync(id);
}
