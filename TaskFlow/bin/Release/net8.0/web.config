<?xml version="1.0" encoding="utf-8"?>
<!-- web.config tối ưu cho Somee.com (IIS + ASP.NET Core Module V2) -->
<configuration>
  <system.webServer>
    <handlers>
      <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
    </handlers>
    <!-- hostingModel="inprocess" để dùng chung process với IIS - nhanh hơn và ổn định hơn -->
    <aspNetCore processPath="dotnet"
                arguments=".\TaskFlow.dll"
                stdoutLogEnabled="false"
                stdoutLogFile=".\logs\stdout"
                hostingModel="inprocess">
      <environmentVariables>
        <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
      </environmentVariables>
    </aspNetCore>
    <!-- WebSocket BẮT BUỘC phải bật cho Blazor Server (SignalR) -->
    <webSocket enabled="true" />
  </system.webServer>
</configuration>
